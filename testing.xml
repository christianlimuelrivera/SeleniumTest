<?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="methods" thread-count="2">

    <!-- ⚙️ Global Parameters: These can be read via ConfigReader or System.getProperty() -->
    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="false"/>
    <listeners>
        <listener class-name="utils.SuiteListener"/>
        <listener class-name="utils.RetryAnnotationTransformer"/>
    </listeners>
<!--    To run it by declaring each test case class-->
        <test name="Test Case" preserve-order="true">
            <classes>
<!--                <class name="Examples.LoginTest" />-->
                <class name="Examples.AlertsFramesModalTest" />
                <class name="Examples.FormTest" />
                <class name="Examples.WebTableTest" />
            </classes>
        </test>
    </suite>

